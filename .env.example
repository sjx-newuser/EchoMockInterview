# =========================================================================
# Echo Mock System 环境变量模板
# 使用方法:
# 1. 复制本文件并重命名为 `.env` (此文件已被 .gitignore 忽略，不会上传到云端)
# 2. 将此处的占位符替换为你真实的 API Key 即可。
# =========================================================================

# -----------------
# 核心大模型配置
# -----------------
# 请在下方填入你申请到的 Gemini API Key 或者是其他大模型的 Key
LLM_API_KEY=""

# 如果使用第三方代理/自定义端点，在这里填入 Base URL（留空则使用官方默认地址）
LLM_BASE_URL=""

# 推荐默认模型：gemini-1.5-pro-latest, gemini-1.5-flash-latest, 或者 gpt-4o, qwen-max 等
LLM_MODEL_NAME="gemini-1.5-pro-latest"

# -----------------
# RAG 检索 Embedding 配置
# -----------------
EMBEDDING_API_KEY=""

# 如果 Embedding 接口也走代理，在这里填入 Base URL（留空则使用官方默认地址）
EMBEDDING_BASE_URL=""

EMBEDDING_MODEL_NAME="text-embedding-v3"
